# Supabase Environment Variables
# Copy this file to .env and fill in your values from your Supabase project dashboard
# https://app.supabase.com → Project Settings → API

VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_PRIMARY_DATA_SOURCE=supabase

# Google Sheets live sync (read-only)
VITE_GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheets-spreadsheet-id
VITE_GOOGLE_SHEETS_SYNC_INTERVAL_MS=30000
# Optional: set to true only if you intentionally want Google Sheets polling
# to run while Supabase is also configured.
VITE_GOOGLE_SHEETS_WITH_SUPABASE=false
